# ── Database ──────────────────────────────────────────────────────────────────
# 로컬은 database.yml 기본값 사용 (localhost:5432 postgres/postgres)
# 프로덕션에서만 필요
# DATABASE_URL=postgres://user:password@host:5432/sp_api_production

# ── SES SMTP ──────────────────────────────────────────────────────────────────
# SES 콘솔 → SMTP settings → Create SMTP credentials 에서 발급
SMTP_ENDPOINT=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=AKIA...
SMTP_PASSWORD=

# SES에서 인증(Verified)된 발신자 이메일
SES_SENDER_EMAIL=noreply@sharablepiggy.com

# ── Rails ─────────────────────────────────────────────────────────────────────
RAILS_ENV=development
