# AWS credentials (set these as environment variables or use IAM roles)
AWS_REGION=us-west-2

# DynamoDB table name (overridden by serverless stage config in production)
TOPICS_TABLE=t_topics-dev
SUBSCRIPTIONS_TABLE=t_subscriptions-dev

# For local development with DynamoDB Local — start with: docker compose up -d
DYNAMODB_ENDPOINT=http://localhost:8000
