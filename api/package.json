{
  "name": "share-it-api",
  "version": "1.0.0",
  "description": "Share-it API service",
  "main": "src/handlers/topics.ts",
  "scripts": {
    "build": "tsc",
    "dev": "DYNAMODB_ENDPOINT=http://localhost:8000 serverless offline --stage dev",
    "db:setup": "npx ts-node scripts/create-local-table.ts",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.758.0",
    "@aws-sdk/lib-dynamodb": "^3.758.0",
    "lodash": "^4.18.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "serverless": "^4.14.3",
    "serverless-offline": "^14.5.0",
    "serverless-plugin-typescript": "^2.1.5",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    },
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
