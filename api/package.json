{
  "name": "share-it-api",
  "version": "1.0.0",
  "description": "Share-it API service",
  "main": "src/handlers/topics.js",
  "scripts": {
    "deploy:dev": "serverless deploy --stage development",
    "deploy:prod": "serverless deploy --stage production",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.758.0",
    "@aws-sdk/lib-dynamodb": "^3.758.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "serverless": "^4.14.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
