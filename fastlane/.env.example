# ── Android / Google Play ──────────────────────────────────────────────────────
SUPPLY_JSON_KEY=/path/to/repo/scripts/xxxxx.json
ANDROID_PACKAGE_NAME=your.package.name
PLAY_TRACK=production
PLAY_RELEASE_STATUS=completed        # completed=즉시공개 / draft=콘솔에서 수동출시

# ── iOS / App Store Connect ────────────────────────────────────────────────────
APP_STORE_CONNECT_API_KEY_KEY_ID=XXXXX
APP_STORE_CONNECT_API_KEY_ISSUER_ID=<Issuer ID>        # appstoreconnect.apple.com → Users & Access → Keys
APP_STORE_CONNECT_API_KEY_KEY_FILEPATH=/path/to/repo/AuthKey_XXXXX.p8
APPLE_DEVELOPER_TEAM_ID=YYYY
APP_STORE_CONNECT_TEAM_ID=YYYY
IOS_SKIP_METADATA=false
IOS_AUTOMATIC_RELEASE=true           # 심사 승인 시 자동 출시
SUBMIT_FOR_REVIEW=true               # iOS 심사 자동 제출

# ── 공통 ───────────────────────────────────────────────────────────────────────
RELEASE_NOTES=Automated production release build.
FLUTTER_FLAVOR=production
FLUTTER_TARGET=lib/main.dart
